# Dependencies
**/node_modules
**/.pnp
**/.pnp.js

# Build directories
/shared/dist/
!/shared/dist/**/*.d.ts
/editorextensions/quodsi_editor_extension/bin
/editorextensions/quodsi_editor_extension/quodsim-react/build

# Lucid package bundle output
/public/quodsim-react/
/package.zip

# TypeScript build info
**/*.tsbuildinfo

# Testing
**/coverage

# Environment files
**/.env*
!**/.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store

# (infrastructure/extracted-config/ was removed 2026-04-27 — held hardcoded secrets)

# Lucid credentials
# Per-provider OAuth secrets used by `lucid-package test-editor-extension`.
# Convention: <providerName>.credentials.local (e.g. lucid.credentials.local,
# kinde.credentials.local). Wildcard pattern so new providers don't need a
# gitignore update.
*.credentials.local

# Local-dev override for the AccountStrip "Create New User" Studio URL.
# Webpack's DefinePlugin reads this file at build time and bakes the
# contents into the extension bundle as __LOCAL_STUDIO_OVERRIDE__.
# Each developer creates their own; cloud bundles never have this file.
local-studio-url.txt

# Azure credentials and publish profiles
*.publishsettings
**/PublishProfiles/
*.pubxml

# Azure Functions local settings (contains connection strings)
local.settings.json

# Connection strings and keys
*.connectionstring
*.key
connections.config

# Azure deployment artifacts
**/deployment-outputs.json

# Azure CLI and PowerShell logs
.azure/
infrastructure/*.log
screenshots/

# Documentation - exclude CSV test data
_docs/cross_rep/

{
  "id": "29e0d321-5cb2-4ae0-a1b6-dabd512c098c",
  "version": "2026.04.13",
  "extensions": [
    {
      "name": "quodsi_editor_extension",
      "title": "Quodsim",
      "products": ["chart"],
      "codePath": "editorextensions\\quodsi_editor_extension\\bin\\extension.js",
      "scopes": [
        "READ",
        "WRITE",
        "DOWNLOAD",
        "SHOW_MODAL",
        "CUSTOM_UI",
        "NETWORK",
        "USER_INFO",
        "OAUTH_TOKEN"
      ]
    }
  ],
  "shapeLibraries": [],
  "oauthProviders": [
    {
      "name": "lucid",
      "title": "Lucid",
      "authorizationUrl": "https://lucid.app/oauth2/authorize",
      "tokenUrl": "https://api.lucid.co/oauth2/token",
      "scopes": ["offline_access"],
      "domainWhitelist": ["https://api.lucid.co"],
      "clientAuthentication": "clientParameters",
      "faviconUrl": "https://cdn-cashy-static-assets.lucidchart.com/marketing/images/LucidSoftwareFavicon.png"
    },
    {
      "name": "kinde",
      "title": "Quodsi Auth",
      "authorizationUrl": "https://quodsim.kinde.com/oauth2/auth",
      "tokenUrl": "https://quodsim.kinde.com/oauth2/token",
      "scopes": ["openid", "profile", "email"],
      "domainWhitelist": ["https://quodsim.kinde.com"],
      "clientAuthentication": "clientParameters",
      "usePkce": true
    }
  ],
  "dataConnectors": [
    {
      "name": "quodsi_data_connector",
      "oauthProviderName": "lucid",
      "callbackBaseUrl": "http://localhost:7071/api/dataConnector/",
      "pollingInterval": 30,
      "dataActions": {
        "Simulate": "simulate",
        "MarkResultsViewed": "markResultsViewed",
        "ImportSimulationResults": "importSimulationResults",
        "SaveAndSubmitSimulation": "saveAndSubmitSimulationAction",
        "SubmitSimulationJob": "submitSimulationJobAction",
        "UploadModelDefinition": "uploadModelDefinitionAction",
        "GetDocumentStatus": "getDocumentStatusAction",
        "ListScenarios": "listScenarios",
        "DeleteScenario": "deleteScenario",
        "GetTaskStatus": "getTaskStatus",
        "CheckScenarioTaskStatus": "checkScenarioTaskStatus",
        "GetActivityCrossRepData": "getActivityCrossRepData",
        "GetEntityCrossRepData": "getEntityCrossRepData",
        "GetResourceCrossRepData": "getResourceCrossRepData",
        "GetScenarioCrossRepData": "getScenarioCrossRepData",
        "GetActivityContentsTimeseries": "getActivityContentsTimeseries",
        "GetActivityInboundQueueTimeseries": "getActivityInboundQueueTimeseries",
        "GetActivityOutboundQueueTimeseries": "getActivityOutboundQueueTimeseries",
        "GetStateSummary": "getStateSummary",
        "GetStateValuesTimeseries": "getStateValuesTimeseries",
        "GetEntityThroughputTimeseries": "getEntityThroughputTimeseries",
        "GetActivityEntitySummary": "getActivityEntitySummary"
      }
    }
  ]
}

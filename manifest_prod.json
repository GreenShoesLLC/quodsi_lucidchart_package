{
  "id": "d38c7ced-35e8-4962-a622-1d3fa480ab58",
  "version": "2026.05.18",
  "extensions": [
    {
      "name": "quodsi_editor_extension",
      "title": "Quodsim",
      "products": ["chart"],
      "codePath": "editorextensions/quodsi_editor_extension/bin/extension.js",
      "scopes": [
        "READ",
        "WRITE",
        "DOWNLOAD",
        "SHOW_MODAL",
        "CUSTOM_UI",
        "NETWORK",
        "USER_INFO",
        "OAUTH_TOKEN"
      ]
    }
  ],
  "shapeLibraries": [],
  "oauthProviders": [
    {
      "name": "lucid",
      "title": "Lucid",
      "authorizationUrl": "https://lucid.app/oauth2/authorize",
      "tokenUrl": "https://api.lucid.co/oauth2/token",
      "scopes": ["offline_access"],
      "domainWhitelist": ["https://api.lucid.co"],
      "clientAuthentication": "clientParameters",
      "faviconUrl": "https://cdn-cashy-static-assets.lucidchart.com/marketing/images/LucidSoftwareFavicon.png"
    },
    {
      "name": "kinde",
      "title": "Quodsi Auth",
      "authorizationUrl": "https://quodsim.kinde.com/oauth2/auth?prompt=login",
      "tokenUrl": "https://quodsim.kinde.com/oauth2/token",
      "revokeTokenUrl": "https://quodsim.kinde.com/oauth2/revoke",
      "scopes": ["openid", "profile", "email"],
      "domainWhitelist": ["https://quodsim.kinde.com"],
      "clientAuthentication": "clientParameters",
      "usePkce": true
    }
  ],
  "dataConnectors": [
    {
      "name": "quodsi_api_data_connector",
      "oauthProviderName": "kinde",
      "callbackBaseUrl": "http://localhost:8000/lucid/",
      "dataActions": {
        "SyncUser": "SyncUser",
        "GetResultsData": "GetResultsData",
        "UpsertModel": "UpsertModel",
        "RemoveModel": "RemoveModel",
        "SyncScenarios": "SyncScenarios",
        "ListScenarios": "ListScenarios",
        "SaveAndSubmitSimulation": "SaveAndSubmitSimulation",
        "SubmitSimulationJob": "SubmitSimulationJob",
        "DeleteScenario": "DeleteScenario",
        "TrackEvent": "TrackEvent",
        "GetMyEntitlements": "GetMyEntitlements",
        "GeneratePortalUrl": "GeneratePortalUrl"
      }
    }
  ]
}
